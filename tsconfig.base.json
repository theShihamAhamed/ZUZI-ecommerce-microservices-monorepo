{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "paths": {
      "@libs": ["./packages/libs"],
      "@libs/*": ["./packages/libs/*"],
      "@middleware": ["./packages/middleware"],
      "@middleware/*": ["./packages/middleware/*"],
      "@error-handler": ["./packages/error-handler"],
      "@error-handler/*": ["./packages/error-handler/*"],
      "@shared-components": ["./packages/components"],
      "@shared-components/*": ["./packages/components/*"],
      "@utils": ["./packages/utils"],
      "@utils/*": ["./packages/utils/*"],
      "@packages": ["./packages"],
      "@packages/*": ["./packages/*"]
    },
    "customConditions": ["@ecommerceapp/source"]
  }
}
