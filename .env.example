DATABASE_URL="replace-with-mongodb-connection-string"
REDIS_DATABASE_URI="redis://localhost:6379"

SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SERVICE="gmail"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-app-password"

REGISTRATION_SECRET="replace-with-registration-secret"
ACCESS_TOKEN_SECRET="replace-with-access-token-secret"
REFRESH_TOKEN_SECRET="replace-with-refresh-token-secret"

STRIPE_SECRET_KEY="replace-with-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="replace-with-stripe-webhook-secret"
CLIENT_URL="http://localhost:3000"

IMAGEKIT_PRIVATE_KEY="private_replace_me"

KAFKA_ENABLED="false"
KAFKA_BROKER="pkc-example.region.provider.confluent.cloud:9092"
KAFKA_API_KEY="replace-with-kafka-api-key"
KAFKA_API_SECRET="replace-with-kafka-api-secret"
KAFKA_ANALYTICS_ENABLED="true"
KAFKAJS_NO_PARTITIONER_WARNING="1"

CHAT_SERVICE_URL="http://localhost:6006"
CHAT_KAFKA_TOPIC="chat.new_message"
CHAT_KAFKA_GROUP_ID="chat-message-db-writer"
CHAT_MESSAGE_FLUSH_INTERVAL_MS="3000"
CHAT_MESSAGE_FLUSH_MAX_BATCH="100"
CHAT_PRESENCE_TTL_SECONDS="60"

ADMIN_SETUP_TOKEN="replace-with-admin-setup-token"
ADMIN_SEED_NAME="Local Admin"
ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_PASSWORD="replace-with-strong-password"

PLATFORM_COMMISSION_RATE="10"

NOTIFICATION_SERVICE_URL="http://localhost:6008"
NOTIFICATION_INTERNAL_TOKEN="replace-with-notification-internal-token"
NOTIFICATION_KAFKA_TOPIC="notification.events"
NOTIFICATION_KAFKA_GROUP_ID="notification-service"
